// ============================================================
// WheelImage — картинка руля, встроенная в код как base64 PNG
// (256x256), чтобы не таскать отдельный файл wheel.png рядом
// с приложением. Собрано generated by gen_wheel_image.py.
// ============================================================

String[] WHEEL_PNG_B64 = {
  "",
  "",
  "",
  "",
  ""
};

PImage decodeWheelImage() {
  try {
    StringBuilder sb = new StringBuilder();
    for (String s : WHEEL_PNG_B64) sb.append(s);
    byte[] bytes = java.util.Base64.getDecoder().decode(sb.toString());
    java.awt.image.BufferedImage bImg = javax.imageio.ImageIO.read(new java.io.ByteArrayInputStream(bytes));
    return new PImage(bImg);
  } catch (Exception e) {
    Log.error("SYSTEM", strings.get("Не удалось декодировать картинку руля: ", "Failed to decode wheel image: ") + e.getMessage());
    return null;
  }
}
